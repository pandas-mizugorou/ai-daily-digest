{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AI Daily Digest day file",
  "type": "object",
  "required": ["date", "generated_at", "categories"],
  "properties": {
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "ターゲット日 (YYYY-MM-DD, JST)"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO8601 (JST タイムゾーン推奨)"
    },
    "schema_version": {
      "type": "string",
      "description": "スキーマバージョン。1.x = 旧 5 カテゴリ / 2.x = Phase A 以降の Top Picks + 拡張カテゴリ。未定義のときは 1.x として扱う"
    },
    "headline": {
      "type": "string",
      "description": "その日のヘッドライン (1 文)"
    },
    "summary_ja": {
      "type": "string",
      "description": "その日の総括 (3-4 行)"
    },
    "stats": {
      "type": "object",
      "properties": {
        "total_collected": { "type": "integer", "minimum": 0 },
        "after_dedup": { "type": "integer", "minimum": 0 },
        "selected": { "type": "integer", "minimum": 0 },
        "top_picks_count": { "type": "integer", "minimum": 0, "maximum": 7, "description": "Top Picks に選ばれた件数 (5-7、Phase A 以降)" },
        "by_category": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 },
          "description": "カテゴリ ID → 件数のマップ (Phase A 以降)"
        }
      }
    },
    "top_picks": {
      "type": "array",
      "minItems": 0,
      "maxItems": 7,
      "description": "その日の必読 5-7 件 (categories[].items[].id を参照)。フロントは先頭固定でハイライト表示する。Phase A 以降の新フィールド (optional)",
      "items": {
        "type": "object",
        "required": ["id", "rank"],
        "properties": {
          "id": { "type": "string", "description": "item.id への参照" },
          "rank": { "type": "integer", "minimum": 1, "maximum": 7 },
          "reason": { "type": "string", "description": "選定理由 (デバッグ用 / フロント非表示)" }
        }
      }
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "items"],
        "properties": {
          "id": {
            "type": "string",
            "enum": [
              "new_models", "tools_apps", "agents", "multimodal",
              "research_papers", "industry_business", "regulation_policy",
              "community_buzz", "japan", "china",
              "tools", "research", "industry"
            ],
            "description": "Phase A 以降は新 ID (10 種) を使う。tools/research/industry は旧 ID として保持 (後方互換)"
          },
          "label_ja": { "type": "string" },
          "label_en": { "type": "string" },
          "items": {
            "type": "array",
            "items": { "$ref": "#/$defs/item" }
          }
        }
      }
    },
    "skipped_sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source", "reason"],
        "properties": {
          "source": { "type": "string" },
          "reason": { "type": "string" },
          "fallback_used": { "type": "string" }
        }
      }
    }
  },
  "$defs": {
    "item": {
      "type": "object",
      "required": ["id", "title", "url", "source", "published_at", "summary_ja", "scores", "figure"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "title_ja": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "source": { "type": "string", "description": "ベンダー識別子 (anthropic / openai 等)" },
        "source_label": { "type": "string", "description": "表示用ラベル" },
        "source_type": {
          "type": "string",
          "enum": ["official", "media", "academic", "community", "china", "japan_corp", "japan_community", "aggregator"],
          "description": "ソースのタイプ。スコアリング bias と UI 表示の仕分けに使う (Phase A 以降、optional)"
        },
        "category": {
          "type": "string",
          "description": "本記事の所属カテゴリ ID (冗長だが 1 item で完結させるため保持、Phase A 以降)"
        },
        "published_at": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "summary_ja": {
          "type": "string",
          "minLength": 250,
          "description": "350-500 字 / 4-6 文の日本語要約。元記事を読まなくても内容が完結するレベル: (1) 主役と何が起きたか (2) 具体的な数字と条件 (3) 背景・位置付け (4) 読者への影響"
        },
        "key_points_ja": {
          "type": "array",
          "items": { "type": "string", "minLength": 30 },
          "minItems": 3,
          "maxItems": 6,
          "description": "各項目は 50-120 字、具体的な数字 + 固有名詞 + 結論を含む完結文。単なる事実列挙ではなく、何が新しいか / どう使えるかまで触れる"
        },
        "scores": {
          "type": "object",
          "required": ["importance", "depth", "practicality", "freshness", "total"],
          "properties": {
            "importance": { "type": "integer", "minimum": 1, "maximum": 5 },
            "depth": { "type": "integer", "minimum": 1, "maximum": 5 },
            "practicality": { "type": "integer", "minimum": 1, "maximum": 5 },
            "freshness": { "type": "integer", "minimum": 0, "maximum": 5 },
            "total": { "type": "integer", "minimum": 0, "maximum": 20 },
            "source_type_bias": {
              "type": "integer",
              "minimum": -2,
              "maximum": 2,
              "description": "ソースタイプ別の importance 補正 (公式 0 / 解説 -1 / 学術 +1 / コミュニティ -1 / 中華圏 0)。Phase A 以降、optional"
            },
            "seen_penalty": {
              "type": "integer",
              "minimum": -3,
              "maximum": 0,
              "description": "既出ペナルティの freshness 減点量 (last_seen_count に応じて -1〜-3、optional)"
            }
          }
        },
        "reaction_signal": {
          "type": "object",
          "description": "コミュニティ反響シグナル (日本語ソース + Reddit + HN 拡張で使用)",
          "properties": {
            "kind": {
              "type": "string",
              "enum": ["hatena", "qiita", "zenn", "hn", "reddit_top", "semantic_scholar", "x_trend"]
            },
            "users": { "type": "integer" },
            "likes": { "type": "integer" },
            "stocks": { "type": "integer" },
            "liked": { "type": "integer" },
            "points": { "type": "integer" },
            "min_score": { "type": "integer" },
            "citation_count": { "type": "integer" }
          }
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "lang": {
          "type": "string",
          "enum": ["en", "ja", "zh", "other"]
        },
        "figure": {
          "$ref": "#/$defs/figure",
          "description": "**必須**。図だけで記事の核心が直感的に分かる視覚図解。記事の性質に応じて 4 種から選ぶ: comparison (旧 vs 新比較) / metric-bars (横棒グラフ) / timeline (段階展開) / summary-card (汎用構造化)。具体的な数字が乏しい記事は summary-card にフォールバックして必ず生成 (記事内の事実のみ使用、創作禁止)"
        }
      }
    },
    "figure": {
      "type": "object",
      "required": ["type", "alt", "data"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["summary-card", "comparison", "metric-bars", "timeline"],
          "description": "図解パターン。記事の性質に応じて選択。comparison: 旧 vs 新 / 他社 vs 自社の対比 / metric-bars: ベンチマークなど 3-7 指標の横棒グラフ / timeline: ロードマップ・段階展開 / summary-card: その他汎用 (5 セクション構造)"
        },
        "caption": {
          "type": "string",
          "maxLength": 30,
          "description": "図解の主題 (図の見出し)。任意"
        },
        "alt": {
          "type": "string",
          "minLength": 60,
          "maxLength": 280,
          "description": "図解の内容を文章化したスクリーンリーダー用テキスト (60-280字)。図に表れている全ての情報を文章として読める形で"
        },
        "data": {
          "oneOf": [
            { "$ref": "#/$defs/figureDataSummaryCard" },
            { "$ref": "#/$defs/figureDataComparison" },
            { "$ref": "#/$defs/figureDataMetricBars" },
            { "$ref": "#/$defs/figureDataTimeline" }
          ]
        }
      }
    },
    "figureDataSummaryCard": {
      "type": "object",
      "required": ["headline", "tldr", "points"],
      "additionalProperties": false,
      "description": "汎用構造化型。質的解説や量的事実が分散している記事向け。5 セクション (headline / tldr / points / context / impact)",
      "properties": {
        "headline": {
          "type": "string",
          "minLength": 20,
          "maxLength": 80,
          "description": "記事の核心を 1 行に圧縮した見出し (20-80字)。主役 + 何が起きたか + 主要数字"
        },
        "tldr": {
          "type": "string",
          "minLength": 60,
          "maxLength": 180,
          "description": "3 行で内容を把握できる要約 (60-180字 / 2-3 文)"
        },
        "points": {
          "type": "array",
          "minItems": 3,
          "maxItems": 6,
          "items": {
            "type": "object",
            "required": ["label", "value"],
            "additionalProperties": false,
            "properties": {
              "icon": { "type": "string", "maxLength": 4 },
              "label": { "type": "string", "minLength": 2, "maxLength": 12 },
              "value": { "type": "string", "minLength": 1, "maxLength": 36 },
              "note": { "type": "string", "maxLength": 50 },
              "description": { "type": "string", "maxLength": 160 },
              "tone": {
                "type": "string",
                "enum": ["default", "primary", "success", "warning", "danger", "info"],
                "default": "default"
              }
            }
          }
        },
        "context": { "type": "string", "maxLength": 200 },
        "impact": { "type": "string", "minLength": 30, "maxLength": 160 }
      }
    },
    "figureDataComparison": {
      "type": "object",
      "required": ["headline", "before", "after", "metrics"],
      "additionalProperties": false,
      "description": "Before / After 比較型。旧バージョン vs 新バージョン、他社 vs 自社、規制前 vs 規制後 などの対比に最適。両側の値を横棒グラフで並列表示する",
      "properties": {
        "headline": {
          "type": "string",
          "minLength": 16,
          "maxLength": 80,
          "description": "対比の核心を 1 行で (例: 'Claude Opus 5: 主要 4 指標で前世代を全面更新')"
        },
        "before": {
          "type": "object",
          "required": ["label"],
          "additionalProperties": false,
          "properties": {
            "label": { "type": "string", "minLength": 1, "maxLength": 24, "description": "比較元の名称 (例: 'Opus 4.5' '従来の RAG')" },
            "sublabel": { "type": "string", "maxLength": 30, "description": "副題・条件 (例: '2026年1月版')" }
          }
        },
        "after": {
          "type": "object",
          "required": ["label"],
          "additionalProperties": false,
          "properties": {
            "label": { "type": "string", "minLength": 1, "maxLength": 24, "description": "比較先の名称 (例: 'Opus 5' 'LongRAG')" },
            "sublabel": { "type": "string", "maxLength": 30 }
          }
        },
        "metrics": {
          "type": "array",
          "minItems": 3,
          "maxItems": 6,
          "description": "比較する指標 3-6 個。各指標で before / after の値とバー長を指定",
          "items": {
            "type": "object",
            "required": ["label", "before", "after"],
            "additionalProperties": false,
            "properties": {
              "icon": { "type": "string", "maxLength": 4, "description": "アイコン絵文字 (任意)" },
              "label": { "type": "string", "minLength": 2, "maxLength": 16, "description": "指標名 (例: 'MMLU' 'コンテキスト' '価格')" },
              "before": { "type": "string", "minLength": 1, "maxLength": 20, "description": "比較元の値 (例: '82.4' '200K' '$15')" },
              "after": { "type": "string", "minLength": 1, "maxLength": 20, "description": "比較先の値 (例: '94.4' '1M' '$15')" },
              "before_pct": { "type": "number", "minimum": 0, "maximum": 100, "description": "横棒の長さ (0-100)。共通のスケールで before/after を比較できるよう正規化。値が大きいほどバーも長く" },
              "after_pct": { "type": "number", "minimum": 0, "maximum": 100 },
              "delta": { "type": "string", "maxLength": 20, "description": "差分の表示 (例: '+12pt' '5x' '据え置き' '-30%')" },
              "delta_tone": {
                "type": "string",
                "enum": ["success", "warning", "danger", "info", "default"],
                "default": "default",
                "description": "改善 = success / 悪化 = danger / 据え置き = info / 中立 = default"
              },
              "note": { "type": "string", "maxLength": 80, "description": "条件・補足 (例: 'ツール使用時の精度' 'コンテキスト 1M tokens 時')" }
            }
          }
        },
        "narrative": { "type": "string", "maxLength": 200, "description": "対比の文脈・背景 (60-200字、強く推奨)" },
        "impact": { "type": "string", "minLength": 30, "maxLength": 160, "description": "読者への影響 (30-160字、強く推奨)" }
      }
    },
    "figureDataMetricBars": {
      "type": "object",
      "required": ["headline", "bars"],
      "additionalProperties": false,
      "description": "横棒グラフ型。3-7 個の数値指標を一覧で見せる。ベンチマーク結果、複数モデルの性能比較、機能スコアなどに最適",
      "properties": {
        "headline": {
          "type": "string",
          "minLength": 16,
          "maxLength": 80,
          "description": "図の主題 (例: 'Claude Opus 5: ベンチマーク 5 指標で SoTA 更新')"
        },
        "scale": {
          "type": "object",
          "additionalProperties": false,
          "description": "スケール表記 (任意)",
          "properties": {
            "max_label": { "type": "string", "maxLength": 24, "description": "100% 時の意味 (例: 'スコア 100' 'MMLU 上限')" },
            "unit": { "type": "string", "maxLength": 16, "description": "単位 (例: 'pt' '%' 'tokens')" }
          }
        },
        "bars": {
          "type": "array",
          "minItems": 3,
          "maxItems": 7,
          "items": {
            "type": "object",
            "required": ["label", "value", "pct"],
            "additionalProperties": false,
            "properties": {
              "icon": { "type": "string", "maxLength": 4 },
              "label": { "type": "string", "minLength": 2, "maxLength": 24, "description": "指標名 (例: 'MMLU' 'HumanEval' 'GSM8K')" },
              "value": { "type": "string", "minLength": 1, "maxLength": 20, "description": "実測値の表示 (例: '94.4' '95.2 / 100')" },
              "pct": { "type": "number", "minimum": 0, "maximum": 100, "description": "バーの長さ (0-100)。同じスケールで複数バーを比較できるよう正規化" },
              "baseline_pct": { "type": "number", "minimum": 0, "maximum": 100, "description": "比較基準値の位置 (任意。前世代や他社のスコア)" },
              "baseline_label": { "type": "string", "maxLength": 24, "description": "比較基準の名称 (例: 'Opus 4.5' 'GPT-4')" },
              "delta": { "type": "string", "maxLength": 20, "description": "差分 (例: '+12pt' '+8.1')" },
              "tone": { "type": "string", "enum": ["default", "primary", "success", "warning", "danger", "info"], "default": "primary" },
              "note": { "type": "string", "maxLength": 100, "description": "1 行補足 (例: '推論系 SoTA 更新' '前世代比 +14%')" }
            }
          }
        },
        "narrative": { "type": "string", "maxLength": 200, "description": "数値の文脈 (60-200字、強く推奨)" },
        "impact": { "type": "string", "minLength": 30, "maxLength": 160 }
      }
    },
    "figureDataTimeline": {
      "type": "object",
      "required": ["headline", "events"],
      "additionalProperties": false,
      "description": "タイムライン型。段階的展開・ロードマップ・バージョン履歴に最適。3-7 イベントを縦並びで表示",
      "properties": {
        "headline": {
          "type": "string",
          "minLength": 16,
          "maxLength": 80,
          "description": "ロードマップの主題 (例: 'Claude 4 → 5 ロードマップ' 'AgentKit リリース計画')"
        },
        "events": {
          "type": "array",
          "minItems": 3,
          "maxItems": 7,
          "items": {
            "type": "object",
            "required": ["when", "label"],
            "additionalProperties": false,
            "properties": {
              "when": { "type": "string", "minLength": 2, "maxLength": 24, "description": "時点表記 (例: '2026/05' 'Q3 2026' 'Day 1' '本日')" },
              "label": { "type": "string", "minLength": 2, "maxLength": 50, "description": "イベント名 (例: 'Opus 5 GA' 'Sonnet 5 公開予定')" },
              "description": { "type": "string", "maxLength": 140, "description": "イベントの内容説明 (40-140字、強く推奨)。なぜ重要か / 何が起きるか" },
              "status": {
                "type": "string",
                "enum": ["past", "now", "upcoming"],
                "default": "past",
                "description": "状態。past = 完了済み (●) / now = 今この時点 (◉ 強調) / upcoming = 将来予定 (○)"
              },
              "tone": { "type": "string", "enum": ["default", "primary", "success", "warning", "danger", "info"], "default": "default" }
            }
          }
        },
        "narrative": { "type": "string", "maxLength": 200, "description": "タイムラインの文脈 (60-200字、強く推奨)" },
        "impact": { "type": "string", "minLength": 30, "maxLength": 160 }
      }
    }
  }
}
