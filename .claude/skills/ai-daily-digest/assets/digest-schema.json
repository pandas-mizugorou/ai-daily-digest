{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AI Daily Digest day file",
  "type": "object",
  "required": ["date", "generated_at", "categories"],
  "properties": {
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "ターゲット日 (YYYY-MM-DD, JST)"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO8601 (JST タイムゾーン推奨)"
    },
    "headline": {
      "type": "string",
      "description": "その日のヘッドライン (1 文)"
    },
    "summary_ja": {
      "type": "string",
      "description": "その日の総括 (2-3 行)"
    },
    "stats": {
      "type": "object",
      "properties": {
        "total_collected": { "type": "integer", "minimum": 0 },
        "after_dedup": { "type": "integer", "minimum": 0 },
        "selected": { "type": "integer", "minimum": 0 }
      }
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "items"],
        "properties": {
          "id": {
            "type": "string",
            "enum": ["new_models", "tools", "research", "industry", "japan"]
          },
          "label_ja": { "type": "string" },
          "label_en": { "type": "string" },
          "items": {
            "type": "array",
            "items": { "$ref": "#/$defs/item" }
          }
        }
      }
    },
    "skipped_sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source", "reason"],
        "properties": {
          "source": { "type": "string" },
          "reason": { "type": "string" },
          "fallback_used": { "type": "string" }
        }
      }
    }
  },
  "$defs": {
    "item": {
      "type": "object",
      "required": ["id", "title", "url", "source", "published_at", "summary_ja", "scores"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "title_ja": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "source": { "type": "string", "description": "ベンダー識別子 (anthropic / openai 等)" },
        "source_label": { "type": "string", "description": "表示用ラベル" },
        "published_at": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "summary_ja": { "type": "string" },
        "key_points_ja": {
          "type": "array",
          "items": { "type": "string" },
          "maxItems": 5
        },
        "scores": {
          "type": "object",
          "required": ["importance", "depth", "practicality", "freshness", "total"],
          "properties": {
            "importance": { "type": "integer", "minimum": 1, "maximum": 5 },
            "depth": { "type": "integer", "minimum": 1, "maximum": 5 },
            "practicality": { "type": "integer", "minimum": 1, "maximum": 5 },
            "freshness": { "type": "integer", "minimum": 0, "maximum": 5 },
            "total": { "type": "integer", "minimum": 0, "maximum": 20 }
          }
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "lang": {
          "type": "string",
          "enum": ["en", "ja", "other"]
        }
      }
    }
  }
}
