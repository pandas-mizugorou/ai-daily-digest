.DS_Store
Thumbs.db
*.log
.vscode/
.idea/
node_modules/

# Local-only working files
# data/_seen.json — Phase A 以降はリポジトリ管理に移行（既出ペナルティの routine 永続化のため）
data/_drafts/

# Push 購読情報は端末識別情報のため public リポジトリに含めない。
# 本番は GitHub Secret SUBSCRIPTIONS_JSON で管理し、ローカルのみ下記ファイルを使う。
data/subscriptions.json

# send-push.mjs が毎回残す実行結果サマリ (workflow のアラート判定専用、コミット不要)
data/_push-status.json

# validate-digest.mjs の図解検証レポート (実行ごとのテレメトリ。CI のステップサマリで可視化、コミット不要)
data/_validation/

# collect.mjs が出力する収集候補プール (中間生成物。Claude が読んで Step 6 以降に使う作業データ。
# 公開対象は最終 data/<date>.json なのでコミット不要)
data/_collected/
